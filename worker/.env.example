# worker 로컬 환경변수. 실제 .env 는 커밋 금지.
DATABASE_URL=postgres://inwoo@localhost:5432/reportlens_dev

# 업로드 스토리지(로컬). api 와 같은 경로를 가리켜야 함.
STORAGE_DRIVER=local
UPLOAD_DIR=/Users/inwoo/Desktop/사이드프로젝트/리포트렌즈/api/.uploads

# LLM 프로바이더: mock(키 불필요, 로컬 기본) | gemini
LLM_PROVIDER=mock
# GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash-001

# 폴링 주기(초)
POLL_INTERVAL=3
