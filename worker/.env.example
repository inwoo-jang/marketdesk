# worker 로컬 환경변수. 실제 .env 는 커밋 금지.
DATABASE_URL=postgres://inwoo@localhost:5432/reportlens_dev

# 업로드 스토리지(로컬). api 와 같은 경로를 가리켜야 함.
STORAGE_DRIVER=local
UPLOAD_DIR=/Users/inwoo/Desktop/사이드프로젝트/마켓데스크/api/.uploads

# LLM 프로바이더: mock(키 불필요) | claude(터미널 claude CLI 직접 호출, 무제한·키 불필요=개발자 모드) | gemini(무료 API 키)
LLM_PROVIDER=claude
# claude CLI 모델(비우면 기본). 예: sonnet / opus
CLAUDE_MODEL=
# Gemini 쓸 때만(무료 키). 모델은 무료 티어 가능한 것으로(gemini-2.5-flash 확인됨).
# GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash

# 폴링 주기(초)
POLL_INTERVAL=3
