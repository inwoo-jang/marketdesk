# worker 로컬 환경변수. 실제 .env 는 커밋 금지.
DATABASE_URL=postgres://inwoo@localhost:5432/reportlens_dev

# 업로드 스토리지(로컬). api 와 같은 경로를 가리켜야 함.
STORAGE_DRIVER=local
UPLOAD_DIR=/Users/inwoo/Desktop/사이드프로젝트/마켓데스크/api/.uploads

# 기본 분석 엔진(폴백). 리포트별 엔진은 업로드 시 사용자 설정(개발자는 앱에서 CLI 엔진 선택)으로 결정되어 우선함.
# mock(키 불필요) | claude(터미널 CLI, 무제한·키 불필요) | codex(CLI, 로그인 계정) | gemini(무료 API 키)
LLM_PROVIDER=gemini
# claude CLI 모델(비우면 기본). 예: sonnet / opus
CLAUDE_MODEL=
# codex CLI 모델(비우면 기본). 예: gpt-5-codex
CODEX_MODEL=
# codex 실행 경로(PATH 에 있으면 codex). 앱 번들 경로 예: /Applications/Codex.app/Contents/Resources/codex
CODEX_CLI_PATH=codex
# Gemini 쓸 때만(무료 키). 모델은 무료 티어 가능한 것으로(gemini-2.5-flash 확인됨).
# GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash

# 폴링 주기(초)
POLL_INTERVAL=3
