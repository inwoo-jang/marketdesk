# api 로컬 개발 환경변수. 실제 .env 는 커밋 금지.
DATABASE_URL=postgres://inwoo@localhost:5432/reportlens_dev
PORT=8787
# 프론트(web) origin (CORS 허용)
WEB_ORIGIN=http://localhost:3000
# 세션 쿠키 서명 키(로컬 개발용. 운영은 Secrets Manager)
SESSION_SECRET=dev-insecure-secret-change-me
# 로컬 dev 로그인 사용(운영은 false 로 끄고 Cognito 사용)
DEV_AUTH_ENABLED=true
