# api 로컬 개발 환경변수. 실제 .env 는 커밋 금지.
DATABASE_URL=postgres://inwoo@localhost:5432/reportlens_dev
PORT=8787
# 프론트(web) origin (CORS 허용)
WEB_ORIGIN=http://localhost:3000
# 세션 쿠키 서명 키(로컬 개발용. 운영은 Secrets Manager)
SESSION_SECRET=dev-insecure-secret-change-me
# 로컬 dev 로그인 사용(운영은 false 로 끄고 Cognito 사용)
DEV_AUTH_ENABLED=true
# 개발자 모드: 분석 무제한(무료 3회/일 게이팅 우회). 본인 테스트용. 운영은 미설정/false.
DEV_UNLIMITED=true
# 개발자 계정 이메일(쉼표 구분). 이 계정만 설정에서 분석 엔진(로컬 Claude/Codex CLI) 선택 가능.
# DEV_EMAILS=you@example.com
# 용어 풀이 LLM: claude(CLI) | mock
DEFINE_PROVIDER=claude

# 한국투자증권 KIS Developers(주가 시세). 실전투자계좌 App Key/Secret. 읽기 전용 시세만 사용.
# 미설정 시 주가 기능만 비활성(나머지 정상 동작).
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# KIS_APP_KEY=...
# KIS_APP_SECRET=...

# BYO(본인 API 키) 암호화용 앱 시크릿. openssl rand -base64 32 로 생성, api·worker 동일 값.
# APP_ENC_KEY=
