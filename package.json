{
  "name": "reportlens",
  "version": "0.0.0",
  "private": true,
  "description": "마켓데스크 - 산업리포트를 목적별 렌즈로 구조화 요약·누적하는 도구 (모노레포)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web,worker -c blue,green,magenta \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:api": "pnpm --filter @reportlens/api dev",
    "dev:web": "pnpm --filter @reportlens/web dev",
    "dev:worker": "pnpm --filter @reportlens/worker dev",
    "db:seed": "pnpm --filter @reportlens/db seed",
    "typecheck": "pnpm --filter @reportlens/db typecheck && pnpm --filter @reportlens/infra typecheck",
    "db:generate": "pnpm --filter @reportlens/db generate",
    "db:migrate": "pnpm --filter @reportlens/db migrate",
    "db:push": "pnpm --filter @reportlens/db push",
    "db:studio": "pnpm --filter @reportlens/db studio"
  }
}
